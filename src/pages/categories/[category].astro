---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { formatDate, sortPosts } from "../../lib/content";
import { getAllPosts } from "../../lib/data";

export async function getStaticPaths() {
  const posts = getAllPosts();
  const categories = [...new Set(posts.flatMap((p) => p.categories))];
  return categories.map((category) => ({
    params: { category },
    props: { category }
  }));
}

const { category } = Astro.props;
const posts = getAllPosts();
const related = sortPosts(posts.filter((post) => post.categories.includes(category)));
---

<BaseLayout title={`Category: ${category}`}>
  <section class="post-header">
    <p class="meta">CATEGORY</p>
    <h1 class="post-title">{category}</h1>
  </section>
  <section class="list">
    {
      related.map((post) => (
        <article class="card">
          <p class="meta">{formatDate(post.date)}</p>
          <h2><a href={`/posts/${post.slug}/`}>{post.title}</a></h2>
        </article>
      ))
    }
  </section>
</BaseLayout>
